# ---------------------------------------------------------------------------
# AI Job Assistant — Example environment variables
#
# Copy this file to `.env` (which is git-ignored) and adjust values as needed:
#     cp .env.example .env
#
# Only the variables needed for Epic 1 (infrastructure) are required right now.
# AI provider keys are listed for forward-compatibility but are NOT used yet.
# ---------------------------------------------------------------------------

# ----- Database (PostgreSQL) -----
# These configure the `db` service in docker-compose and the connection string.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_job_assistant

# Full connection string the backend uses to reach PostgreSQL.
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_job_assistant

# ----- Backend behavior -----
# Comma-separated list of allowed CORS origins, or "*" for any (dev-friendly).
BACKEND_CORS_ORIGINS=*
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ----- Frontend -----
# Public URL the browser uses to reach the backend API.
# In Docker the browser runs on the host, so it talks to the published port.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ----- AI Provider -----
# Options: mock | openai | claude
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# ----- Production (see DEPLOYMENT.md and .env.production.example) -----
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app
# BACKEND_CORS_ORIGINS=https://your-app.vercel.app
