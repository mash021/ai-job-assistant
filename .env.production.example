# ---------------------------------------------------------------------------
# Production environment variables (Epic 9)
#
# Copy values into your hosting dashboards — never commit real secrets.
# See DEPLOYMENT.md for step-by-step setup (Vercel + Railway).
# ---------------------------------------------------------------------------

# ----- Vercel (frontend) -----
# Public backend URL — must match your Railway (or Render) API domain.
NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# ----- Railway PostgreSQL (auto-injected when you link the plugin) -----
# Railway may provide postgres:// — the backend normalizes it automatically.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ----- Railway backend service -----
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
LOG_LEVEL=INFO

# Comma-separated Vercel URL(s). No wildcards in production.
BACKEND_CORS_ORIGINS=https://your-app.vercel.app

# Railway sets PORT automatically — do not override unless required.
# PORT=8000
